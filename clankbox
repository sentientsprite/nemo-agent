  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  sleep 0.3
}

# ── Inventory Check ─────────────────────────────

check_inventory() {
  echo "  📋 Checking inventory..."
  echo ""
  
  if [ -d "$CLANKBOX_DIR" ]; then
    echo "  ✅ ClankBox headquarters ... equipped"
  else
    echo "  ❌ ClankBox not found at $CLANKBOX_DIR"
    exit 1
  fi
  
  if command -v open &>/dev/null; then
    echo "  ✅ Browser launcher ... equipped"
  else
    echo "  ⚠️  No browser launcher found"
  fi
  
  echo ""
  sleep 0.3
}

# ── Launch Office ───────────────────────────────

launch_office() {
  echo "  🏢 Opening the ClankBox..."
  echo ""
  
  # Progress animation
  frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  for i in {1..20}; do
    printf "\r  %s Establishing connection..." "${frames[$((i % 10))]}"
    sleep 0.1
  done
  printf "\r  ✅ Connection established!       \n"
  echo ""
  
  # Open browser
  if command -v open &>/dev/null; then
    open "$DASHBOARD_URL"
    echo "  🎮 The ClankBox is now open in your browser"
    echo "  🌐 $DASHBOARD_URL"
  else
    echo "  🌐 Open this URL in your browser:"
    echo "     $DASHBOARD_URL"
  fi
  
  echo ""
  echo "  💡 Commands you can type in the ClankBox:"
  echo "     status    — Get full team status"
  echo "     priority  — See task queue"
  echo "     @Agent    — Mention specific agent"
  echo ""
}

